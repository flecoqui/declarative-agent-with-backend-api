{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "id": "${{TEAMS_APP_ID}}",
  "version": "1.0.0",
  "developer": {
    "name": "Contoso",
    "websiteUrl": "https://contoso.example.com",
    "privacyUrl": "https://contoso.example.com/privacy",
    "termsOfUseUrl": "https://contoso.example.com/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "DA Task Assistant",
    "full": "Declarative Agent Task Assistant"
  },
  "description": {
    "short": "Manage your tasks from Microsoft 365 Copilot.",
    "full": "A declarative agent that lets you list, create and complete personal tasks stored in a private Entra ID-protected backend API."
  },
  "accentColor": "#2A6DF4",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "taskAssistant",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": []
}
